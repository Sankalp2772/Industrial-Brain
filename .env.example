# Industrial Brain Environment Configuration

# --------------------------
# LLM Integration
# --------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------
# Neo4j Database
# --------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --------------------------
# Backend Settings
# --------------------------
API_V1_STR=/api/v1
PROJECT_NAME="Industrial Brain"

# Note: In docker-compose, these paths map to volume mounts
UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed
KNOWLEDGE_DIR=./knowledge
