# ============================================================
# Industrial Brain — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Gemini AI (Google AI Studio) ---
# Get API keys at: https://aistudio.google.com/apikey
GEMINI_API_KEY_1=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here   # Optional — enables key rotation
GEMINI_API_KEY_3=your_gemini_api_key_3_here   # Optional — enables key rotation

# --- Neo4j Graph Database ---
# Get a free instance at: https://neo4j.com/cloud/platform/aura-graph-database/
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# --- Authentication ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_strong_secret_key_here_at_least_32_characters_long

# --- Application Settings (optional overrides) ---
# DATABASE_URL=sqlite:///./industrial_brain.db
# UPLOAD_DIR=uploads/raw
# MAX_UPLOAD_SIZE=104857600
